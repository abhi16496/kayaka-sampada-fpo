# Production env — fill in before deploying

# Database Connection (PostgreSQL)
# Either provide a unified connection string:
DATABASE_URL=postgresql://username:password@host:5432/dbname
# OR provide separate connection parameters:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=registration_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# URLs
FRONTEND_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# AWS SES — required for email notifications on admin approval
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_SES_SENDER=no-reply@yourdomain.com
